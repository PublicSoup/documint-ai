# DocuMint AI - Environment Variables
# Copy this file to .env and fill in your values

# ============================================
# DATABASE
# ============================================
DATABASE_URL="postgresql://user:password@localhost:5432/documint?schema=public"

# ============================================
# AUTHENTICATION (NextAuth.js)
# ============================================
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-super-secret-key-here-generate-with-openssl-rand-base64-32"

# ============================================
# AI BACKEND (LM Studio / Local AI)
# ============================================
# LM Studio runs locally on port 1234 by default
LM_STUDIO_URL="http://localhost:1234/v1"
# Model name as shown in LM Studio (optional, uses default if not set)
LM_STUDIO_MODEL="qwen2.5-coder-7b-instruct"

# ============================================
# GITHUB INTEGRATION (Optional)
# ============================================
# Create an OAuth App at: https://github.com/settings/developers
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""

# ============================================
# STRIPE BILLING (Optional)
# ============================================
# Get keys from: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=""
STRIPE_PUBLISHABLE_KEY=""
STRIPE_WEBHOOK_SECRET=""

# Price IDs for subscription tiers (create in Stripe Dashboard)
STRIPE_PRICE_ID_STARTER=""
STRIPE_PRICE_ID_PRO=""
STRIPE_PRICE_ID_TEAM=""

# ============================================
# SUPABASE (Storage & Auth)
# ============================================
SUPABASE_URL="https://your-project.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# ============================================
# ============================================
# EMAIL (Resend.com)
# ============================================
RESEND_API_KEY="your-resend-api-key"
EMAIL_FROM="DocuMint AI <noreply@documint.ai>"
