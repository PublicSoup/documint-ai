# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug / runtime logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
*.log
loop.log
ACTIVITY.log
ACTIVITY_LOG.md

# env files — never commit secrets
.env
.env.*
!.env.example

# sensitive docs — never commit key docs or debug dumps
STRIPE_KEYS.md
node.zip

# screenshots & local docs
src/ScrennShots/
ACTIVITY_LOG.md
logs/

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
