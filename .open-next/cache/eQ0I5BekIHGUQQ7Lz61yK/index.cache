8 1.63l-9.9 10.2a.5.5 0 0 1-.86-.46l1.92-6.02A1 1 0 0 0 11 14z\"></path></svg><span>10,000 files/mo</span></li><li class=\"flex items-center gap-3 text-sm text-white/60\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-circle-check w-4 h-4 text-green-400\" aria-hidden=\"true\"><circle cx=\"12\" cy=\"12\" r=\"10\"></circle><path d=\"m9 12 2 2 4-4\"></path></svg><span>Onboarding Time Metrics</span></li><li class=\"flex items-center gap-3 text-sm text-white/60\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-circle-check w-4 h-4 text-green-400\" aria-hidden=\"true\"><circle cx=\"12\" cy=\"12\" r=\"10\"></circle><path d=\"m9 12 2 2 4-4\"></path></svg><span>Performance Profiling</span></li><li class=\"flex items-center gap-3 text-sm text-white/60\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-circle-check w-4 h-4 text-green-400\" aria-hidden=\"true\"><circle cx=\"12\" cy=\"12\" r=\"10\"></circle><path d=\"m9 12 2 2 4-4\"></path></svg><span>Team Collab</span></li><li class=\"flex items-center gap-3 text-sm text-white/60\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-circle-check w-4 h-4 text-green-400\" aria-hidden=\"true\"><circle cx=\"12\" cy=\"12\" r=\"10\"></circle><path d=\"m9 12 2 2 4-4\"></path></svg><span>Custom API Access</span></li></ul><a class=\"w-full\" target=\"_self\" href=\"/auth/register?source=pricing_team&amp;intent=trial&amp;plan=team\"><button class=\"inline-flex items-center justify-center whitespace-nowrap rounded-xl text-sm font-medium ring-offset-background transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 disabled:pointer-events-none disabled:opacity-50 shadow-sm h-11 px-6 py-2 w-full bg-white/10 hover:bg-white/20 text-white\" tabindex=\"0\">Get Started</button></a></div></div></div></div></section><section class=\"px-6 pb-20\"><div class=\"max-w-7xl mx-auto\"><div class=\"grid grid-cols-1 lg:grid-cols-3 gap-6 mb-10\"><div class=\"rounded-xl border bg-card/40 text-card-foreground shadow-sm backdrop-blur-md transition-all hover:border-white/10 hover:bg-card/60 hover:shadow-md hover:-translate-y-1 glass-card border-white/10\"><div class=\"p-6\"><h3 class=\"font-bold text-white mb-2\">Start risk-free</h3><p class=\"text-sm text-white/60 leading-relaxed\">Launch on a 14-day trial. Upgrade only when your team sees measurable value.</p></div></div><div class=\"rounded-xl border bg-card/40 text-card-foreground shadow-sm backdrop-blur-md transition-all hover:border-white/10 hover:bg-card/60 hover:shadow-md hover:-translate-y-1 glass-card border-white/10\"><div class=\"p-6\"><h3 class=\"font-bold text-white mb-2\">No migration lock-in</h3><p class=\"text-sm text-white/60 leading-relaxed\">Export your generated docs and architecture artifacts whenever you need.</p></div></div><div class=\"rounded-xl border bg-card/40 text-card-foreground shadow-sm backdrop-blur-md transition-all hover:border-white/10 hover:bg-card/60 hover:shadow-md hover:-translate-y-1 glass-card border-white/10\"><div class=\"p-6\"><h3 class=\"font-bold text-white mb-2\">Enterprise support path</h3><p class=\"text-sm text-white/60 leading-relaxed\">Move from self-serve to team onboarding with guided implementation help.</p></div></div></div><div class=\"glass-card rounded-3xl border border-primary/20 p-8 md:p-10\"><p class=\"text-[11px] uppercase tracking-[0.2em] text-primary mb-4 font-bold\">Buyer objections handled upfront</p><div class=\"grid grid-cols-1 md:grid-cols-2 gap-6\"><div class=\"rounded-2xl border border-white/10 bg-black/20 p-5\"><h4 class=\"font-semibold text-white mb-2\">How fast can we see value?</h4><p class=\"text-sm text-white/60\">Most teams generate production-ready docs and architecture maps in their first session.</p></div><div class=\"rounded-2xl border border-white/10 bg-black/20 p-5\"><h4 class=\"font-semibold text-white mb-2\">Will this fit enterprise security standards?</h4><p class=\"text-sm text-white/60\">DocuMint is built with strict validation, access controls, and auditable workflows by default.</p></div><div class=\"rounded-2xl border border-white/10 bg-black/20 p-5\"><h4 class=\"font-semibold text-white mb-2\">Can we use it with our existing stack?</h4><p class=\"text-sm text-white/60\">Yes — supports modern languages, team workflows, and integrates into current engineering delivery.</p></div><div class=\"rounded-2xl border border-white/10 bg-black/20 p-5\"><h4 class=\"font-semibold text-white mb-2\">What if we outgrow our current plan?</h4><p class=\"text-sm text-white/60\">Upgrade paths are immediate, with higher limits and collaboration controls for scaling teams.</p></div></div></div></div></section><section class=\"px-6 pb-16\"><div class=\"max-w-7xl mx-auto\"><div class=\"glass-card border border-primary/20 rounded-2xl p-5 md:p-6 flex flex-col md:flex-row md:items-center md:justify-between gap-4\"><div><p class=\"text-sm uppercase tracking-[0.2em] text-primary font-bold mb-1\">For teams evaluating now</p><h3 class=\"text-xl md:text-2xl font-black tracking-tight\">Start your 14-day Pro trial and ship production-ready docs this week.</h3></div><div class=\"flex items-center gap-3\"><a target=\"_self\" href=\"/auth/register?source=sticky_conversion_bar_primary&amp;intent=trial&amp;plan=pro\"><button class=\"inline-fl