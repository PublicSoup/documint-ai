# Backend Environment Variables
# Copy this file to .env and fill in your values

# Security
SECRET_KEY=your-super-secret-key-change-this-in-production

# Database (SQLite for now, PostgreSQL URL for production)
DATABASE_URL=sqlite:///./revascan.db

# Stripe (Get these from https://dashboard.stripe.com/apikeys)
STRIPE_API_KEY=sk_live_xxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxx
STRIPE_PRICE_ID_PRO=price_xxxxx
STRIPE_PRICE_ID_ENTERPRISE=price_xxxxx

# Frontend URL (for redirects after payment)
FRONTEND_URL=https://habbitarc.pro

# LM Studio (local AI server)
LM_STUDIO_URL=http://localhost:1234/v1
