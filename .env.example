# DocuMint AI - Environment Variables
# Copy this file to .env and fill in your values

# ============================================
# DATABASE
# ============================================
DATABASE_URL="postgresql://user:password@localhost:5432/documint?schema=public"

# ============================================
# AUTHENTICATION (NextAuth.js)
# ============================================
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-super-secret-key-here-generate-with-openssl-rand-base64-32"

# ============================================
# AI BACKEND (Google Gemini)
# ============================================
# Get your API key from: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=""

# ============================================
# GITHUB INTEGRATION (Optional)
# ============================================
# Create an OAuth App at: https://github.com/settings/developers
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""
# For webhook security (optional)
GITHUB_WEBHOOK_SECRET=""

# ============================================
# STRIPE BILLING (Required)
# ============================================
# Get keys from: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""
STRIPE_WEBHOOK_SECRET=""

# Price IDs for subscription tiers (create in Stripe Dashboard)
STRIPE_PRICE_ID_STARTER=""
STRIPE_PRICE_ID_PRO=""
STRIPE_PRICE_ID_TEAM=""

# Developer mode (simulates Pro plan locally without Stripe)
NEXT_PUBLIC_DEV_PRO="false"

# ============================================
# SUPABASE (Storage & Auth)
# ============================================
SUPABASE_URL="https://your-project.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# ============================================
# Security
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY="your-32-byte-hex-key-here"

# ============================================
# EMAIL (Resend.com)
# ============================================
RESEND_API_KEY="your-resend-api-key"
EMAIL_FROM="DocuMint AI <noreply@documint.ai>"
