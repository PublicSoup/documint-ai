\"text-white\">{</span> <span class=\"text-sky-300\">useState</span><span class=\"text-white\">,</span> <span class=\"text-sky-300\">useEffect</span> <span class=\"text-white\">}</span> <span class=\"text-purple-400\">from</span> <span class=\"text-amber-300\">&quot;react&quot;</span></div><div><span class=\"text-purple-400\">import</span> <span class=\"text-white\">{</span> <span class=\"text-sky-300\">analyzeCode</span> <span class=\"text-white\">}</span> <span class=\"text-purple-400\">from</span> <span class=\"text-amber-300\">&quot;@/lib/ai&quot;</span></div><div class=\"h-4\"></div><div><span class=\"text-purple-400\">export function</span> <span class=\"text-yellow-300\">DocumentationPanel</span><span class=\"text-white\">() <!-- -->{</span></div><div class=\"pl-4\"><span class=\"text-purple-400\">const</span> [<span class=\"text-sky-300\">docs</span>, <span class=\"text-sky-300\">setDocs</span>] = <span class=\"text-yellow-300\">useState</span><span class=\"text-white\">(</span><span class=\"text-amber-300\">&quot;&quot;</span><span class=\"text-white\">)</span></div><div class=\"pl-4 text-gray-500\">// Auto-generate docs with AI</div><div class=\"pl-4\"><span class=\"text-purple-400\">const</span> <span class=\"text-sky-300\">result</span> = <span class=\"text-purple-400\">await</span> <span class=\"text-yellow-300\">analyzeCode</span><span class=\"text-white\">(</span><span class=\"text-sky-300\">code</span><span class=\"text-white\">)</span></div><div class=\"pl-4\"><span class=\"text-purple-400\">return</span> <span class=\"text-white\">&lt;</span><span class=\"text-green-400\">div</span><span class=\"text-white\">&gt;</span>{<span class=\"text-sky-300\">result</span>}<span class=\"text-white\">&lt;/</span><span class=\"text-green-400\">div</span><span class=\"text-white\">&gt;</span></div><div><span class=\"text-white\">}</span></div><div class=\"h-4\"><span class=\"typing-cursor\"></span></div></div></div><div class=\"absolute bottom-4 right-4 px-3 py-1.5 bg-primary/20 border border-primary/30 rounded-lg text-primary text-xs font-sans flex items-center gap-2\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-sparkles w-3 h-3\" aria-hidden=\"true\"><path d=\"M11.017 2.814a1 1 0 0 1 1.966 0l1.051 5.558a2 2 0 0 0 1.594 1.594l5.558 1.051a1 1 0 0 1 0 1.966l-5.558 1.051a2 2 0 0 0-1.594 1.594l-1.051 5.558a1 1 0 0 1-1.966 0l-1.051-5.558a2 2 0 0 0-1.594-1.594l-5.558-1.051a1 1 0 0 1 0-1.966l5.558-1.051a2 2 0 0 0 1.594-1.594z\"></path><path d=\"M20 2v4\"></path><path d=\"M22 4h-4\"></path><circle cx=\"4\" cy=\"20\" r=\"2\"></circle></svg> AI Ready</div></div></div></div></div></section><section class=\"px-6 pb-16\"><div class=\"max-w-7xl mx-auto\"><div class=\"glass-card rounded-3xl border border-white/10 px-8 py-6 md:px-10 md:py-8\"><p class=\"text-[11px] uppercase tracking-[0.25em] text-white/40 text-center mb-6 font-bold\">Trusted by teams shipping production systems</p><div class=\"grid grid-cols-2 md:grid-cols-4 gap-4 md:gap-6 stagger-in\"><div class=\"rounded-2xl border border-white/10 bg-black/20 p-4 md:p-5 text-center\"><div class=\"text-xl md:text-2xl font-black text-primary mb-1\">99.95%</div><div class=\"text-xs md:text-sm text-white/60\">Deployment Readiness</div></div><div class=\"rounded-2xl border border-white/10 bg-black/20 p-4 md:p-5 text-center\"><div class=\"text-xl md:text-2xl font-black text-primary mb-1\">12+ hrs/mo</div><div class=\"text-xs md:text-sm text-white/60\">Avg. Docs Time Saved</div></div><div class=\"rounded-2xl border border-white/10 bg-black/20 p-4 md:p-5 text-center\"><div class=\"text-xl md:text-2xl font-black text-primary mb-1\">100%</div><div class=\"text-xs md:text-sm text-white/60\">Security Review Coverage</div></div><div class=\"rounded-2xl border border-white/10 bg-black/20 p-4 md:p-5 text-center\"><div class=\"text-xl md:text-2xl font-black text-primary mb-1\">&lt; 24h</div><div class=\"text-xs md:text-sm text-white/60\">Support SLA</div></div></div></div></div></section><section id=\"solutions\" class=\"px-6 pb-20\"><div class=\"max-w-7xl mx-auto grid grid-cols-1 lg:grid-cols-2 gap-8\"><div class=\"rounded-xl border bg-card/40 text-card-foreground shadow-sm backdrop-blur-md transition-all hover:border-white/10 hover:bg-card/60 hover:shadow-md hover:-translate-y-1 glass-card border-white/10\"><div class=\"p-8 md:p-10\"><p class=\"text-[11px] uppercase tracking-[0.2em] text-primary mb-4 font-bold\">Executive-ready outcomes</p><h3 class=\"text-3xl md:text-4xl font-black tracking-tight mb-5\">Move from AI demos to production delivery.</h3><p class=\"text-white/60 mb-7 leading-relaxed\">DocuMint AI helps engineering teams ship polished, secure releases with automated documentation, conversion-aware generation, and enterprise controls built in.</p><ul class=\"space-y-4\"><li class=\"flex items-start gap-3 text-white/80\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-circle-check w-5 h-5 text-emerald-400 mt-0.5\" aria-hidden=\"true\"><circle cx=\"12\" cy=\"12\" r=\"10\"></circle><path d=\"m9 12 2 2 4-4\"></path></svg><span>Reduce onboarding friction with always-updated technical docs</span></li><li class=\"flex items-start gap-3 text-white/80\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-circle-check w-5 h-5 text-emerald-400 mt-0.5\" aria-hidden=\"true\"><circle cx=\"12\" cy=\"12\" r=\"10\"></circle><path d=\"m9 12 2 2 4-4\"></path></svg><span>Increase trial-to-paid momentum via launch and conversion playbooks</span></li><li class=\"flex items-start gap-3 text-white/80\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-circle-check w-5 h-5 text-emerald-400 mt-0.5\" aria-hidden=\"true\"><circle cx=\"12\" cy=\"12\" r=\"10\"></circle><path d=\"m9 12 2 2 4-4\"></path></svg><span>Enforce secure defaults with validation, authz, and audit coverage</span></li></ul></div></div><div class=\"rounded-xl border text-card-foreground shadow-sm backdrop-blur-md transition-all hover:border-white/10 hover:bg-card/60 hover:shadow-md hover:-translate-y-1 glass-card border-primary/20 bg-gradient-to-br from-primary/10 to-purple-600/10\"><div class=\"p-8 md:p-10\"><p class=\"text-[11px] uppercase tracking-[0.2em] text-primary mb-4 font-bold\">Why premium teams choose us</p><div class=\"space-y-5\"><div class=\"rounded-2xl border border-white/10 bg-black/20 p-5\"><h4 class=\"font-bold text-white mb-1\">Enterprise-grade architecture</h4><p class=\"text-sm text-white/60\">Typed APIs, strict validation, and auditable changes across critical paths.</p></div><div class=\"rounded-2xl border border-white/10 bg-black/20 p-5\"><h4 class=\"font-bold text-white mb-1\">Growth-aware product engine</h4><p class=\"text-sm text-white/60\">Launch checklists and conversion hooks baked directly into AI generation flows.</p></div><div class=\"rounded-2xl border border-white/10 bg-black/20 p-5\"><h4 class=\"font-bold text-white mb-1\">Developer-first velocity</h4><p class=\"text-sm text-white/60\">Web IDE, AI assistants, and architecture visualization in one unified platform.</p></div></div></div></div></div></section><section class=\"px-6 pb-20\"><div class=\"max-w-7xl mx-auto\"><div class=\"glass-card rounded-3xl border border-white/10 p-8 md:p-10\"><p class=\"text-[11px] uppercase tracking-[0.22em] text-primary mb-6 font-bold text-center\">Proof for enterprise buyers</p><div class=\"grid grid-cols-1 md:grid-cols-3 gap-5\"><div class=\"rounded-xl border text-card-foreground shadow-sm backdrop-blur-md transition-all hover:border-white/10 hover:bg-card/60 hover:shadow-md hover:-translate-y-1 border-white/10 bg-black/20\"><div class=\"p-6\"><p class=\"text-xs uppercase tracking-widest text-white/40 mb-3\">Fintech Platform</p><p class=\"text-2xl font-black text-primary mb-3\">31% faster onboarding</p><p class=\"text-sm text-white/60 leading-relaxed\">Reduced engineering onboarding cycles by keeping architecture and docs continuously in sync.</p></div></div><div class=\"rounded-xl border text-card-foreground shadow-sm backdrop-blur-md transition-all hover:border-white/10 hover:bg-card/60 hover:shadow-md hover:-translate-y-1 border-white/10 bg-black/20\"><div class=\"p-6\"><p class=\"text-xs uppercase tracking-widest text-white/40 mb-3\">SaaS Product Team</p><p class=\"text-2xl font-black text-primary mb-3\">2.4x doc freshness</p><p class=\"text-sm text-white/60 leading-relaxed\">Increased documentation update frequency with AI-assisted generation in normal dev workflows.</p></div></div><div class=\"rounded-xl border text-card-foreground shadow-sm backdrop-blur-md transition-all hover:border-white/10 hover:bg-card/60 hover:shadow-md hover:-translate-y-1 border-white/10 bg-black/20\"><div class=\"p-6\"><p class=\"text-xs uppercase tracking-widest text-white/40 mb-3\">Enterprise IT Org</p><p class=\"text-2xl font-black text-primary mb-3\">42% fewer review loops</p><p class=\"text-sm text-white/60 leading-relaxed\">Security and architecture expectations shifted left with clearer generated technical artifacts.</p></div></div></div></div></div></section><section id=\"features\" class=\"py-32 px-6 relative overflow-hidden\"><div class=\"max-w-7xl mx-auto\"><div class=\"text-center mb-20\"><h2 class=\"text-4xl md:text-5xl font-bold mb-6 italic italic-accent\">Engineered for Excellence</h2><p class=\"text-white/40 text-lg max-w-2xl mx-auto\">We&#x27;ve built all the tools you need to build faster, smarter, and with complete visibility.</p></div><div class=\"grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 stagger-in\"><div><div class=\"rounded-xl border bg-card/40 text-card-foreground shadow-sm backdrop-blur-md transition-all hover:bg-card/60 hover:shadow-md hover:-translate-y-1 glass-card h-full border-white/5 hover:border-primary/30 group card-hover-lift gradient-border-hover\"><div class=\"p-8\"><div class=\"w-14 h-14 rounded-2xl flex items-center justify-center mb-6 group-hover:scale-110 transition-transform duration-500 bg-blue-500/10 text-blue-400 border border-blue-500/20 shadow-lg shadow-blue-500/20\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-code-xml w-8 h-8\" aria-hidden=\"true\"><path d=\"m18 16 4-4-4-4\"></path><path d=\"m6 8-4 4 4 4\"></path><path d=\"m14.5 4-5 16\"></path></svg></div><h3 class=\"text-xl font-bold mb-4\">Cloud IDE</h3><p class=\"text-white/40 leading-relaxed\">A full VS-Code style experience in your browser with real-time AI assistance.</p></div></div></div><div><div class=\"rounded-xl border bg-card/40 text-card-foreground shadow-sm backdrop-blur-md transition-all hover:bg-card/60 hover:shadow-md hover:-translate-y-1 glass-card h-full border-white/5 hover:border-primary/30 group card-hover-lift gradient-border-hover\"><div class=\"p-8\"><div class=\"w-14 h-14 rounded-2xl flex items-center justify-center mb-6 group-hover:scale-110 transition-transform duration-500 bg-amber-500/10 text-amber-400 border border-amber-500/20 shadow-lg shadow-amber-500/20\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-sparkles w-8 h-8\" aria-hidden=\"true\"><path d=\"M11.017 2.814a1 1 0 0 1 1.966 0l1.051 5.558a2 2 0 0 0 1.594 1.594l5.558 1.051a1 1 0 0 1 0 1.966l-5.558 1.051a2 2 0 0 0-1.594 1.594l-1.051 5.558a1 1 0 0 1-1.966 0l-1.051-5.558a2 2 0 0 0-1.594-1.594l-5.558-1.051a1 1 0 0 1 0-1.966l5.558-1.051a2 2 0 0 0 1.594-1.594z\"></path><path d=\"M20 2v4\"></path><path d=\"M22 4h-4\"></path><circle cx=\"4\" cy=\"20\" r=\"2\"></circle></svg></div><h3 class=\"text-xl font-bold mb-4\">AI Documentation</h3><p class=\"text-white/40 leading-relaxed\">Instantly generate human-readable docs from your source code using advanced LLMs.</p></div></div></div><div><div class=\"rounded-xl border bg-card/40 text-card-foreground shadow-sm backdrop-blur-md transition-all hover:bg-card/60 hover:shadow-md hover:-translate-y-1 glass-card h-full border-white/5 hover:border-primary/30 group card-hover-lift gradient-border-hover\"><div class=\"p-8\"><div class=\"w-14 h-14 rounded-2xl flex items-center justify-center mb-6 group-hover:scale-110 transition-transform duration-500 bg-purple-500/10 text-purple-400 border border-purple-500/20 shadow-lg shadow-purple-500/20\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-cpu w-8 h-8\" aria-hidden=\"true\"><path d=\"M12 20v2\"></path><path d=\"M12 2v2\"></path><path d=\"M17 20v2\"></path><path d=\"M17 2v2\"></path><path d=\"M2 12h2\"></path><path d=\"M2 17h2\"></path><path d=\"M2 7h2\"></path><path d=\"M20 12h2\"></path><path d=\"M20 17h2\"></path><path d=\"M20 7h2\"></path><path d=\"M7 20v2\"></path><path d=\"M7 2v2\"></path><rect x=\"4\" y=\"4\" width=\"16\" height=\"16\" rx=\"2\"></rect><rect x=\"8\" y=\"8\" width=\"8\" height=\"8\" rx=\"1\"></rect></svg></div><h3 class=\"text-xl font-bold mb-4\">Agentic Workflows</h3><p class=\"text-white/40 leading-relaxed\">AI agents that can fix bugs, refactor code, and run tests autonomously.</p></div></div></div><div><div class=\"rounded-xl border bg-card/40 text-card-foreground shadow-sm backdrop-blur-md transition-all hover:bg-card/60 hover:shadow-md hover:-translate-y-1 glass-card h-full border-white/5 hover:border-primary/30 group card-hover-lift gradient-border-hover\"><div class=\"p-8\"><div class=\"w-14 h-14 rounded-2xl flex items-center justify-center mb-6 group-hover:scale-110 transition-transform duration-500 bg-emerald-500/10 text-emerald-400 border border-emerald-500/20 shadow-lg shadow-emerald-500/20\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-shield w-8 h-8\" aria-hidden=\"true\"><path d=\"M20 13c0 5-3.5 7.5-7.66 8.95a1 1 0 0 1-.67-.01C7.5 20.5 4 18 4 13V6a1 1 0 0 1 1-1c2 0 4.5-1.2 6.24-2.72a1.17 1.17 0 0 1 1.52 0C14.51 3.81 17 5 19 5a1 1 0 0 1 1 1z\"></path></svg></div><h3 class=\"text-xl font-bold mb-4\">Enterprise Security</h3><p class=\"text-white/40 leading-relaxed\">Bank-grade encryption and isolation for your sensitive codebase and secrets.</p></div></div></div><div><div class=\"rounded-xl border bg-card/40 text-card-foreground shadow-sm backdrop-blur-md transition-all hover:bg-card/60 hover:shadow-md hover:-translate-y-1 glass-card h-full border-white/5 hover:border-primary/30 group card-hover-lift gradient-border-hover\"><div class=\"p-8\"><div class=\"w-14 h-14 rounded-2xl flex items-center justify-center mb-6 group-hover:scale-110 transition-transform duration-500 bg-indigo-500/10 text-indigo-400 border border-indigo-500/20 shadow-lg shadow-indigo-500/20\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-globe w-8 h-8\" aria-hidden=\"true\"><circle cx=\"12\" cy=\"12\" r=\"10\"></circle><path d=\"M12 2a14.5 14.5 0 0 0 0 20 14.5 14.5 0 0 0 0-20\"></path><path d=\"M2 12h20\"></path></svg></div><h3 class=\"text-xl font-bold mb-4\">Universal Support</h3><p class=\"text-white/40 leading-relaxed\">Support for 20+ languages including TS, Python, Rust, Go, and Java.</p></div></div></div><div><div class=\"rounded-xl border bg-card/40 text-card-foreground shadow-sm backdrop-blur-md transition-all hover:bg-card/60 hover:shadow-md hover:-translate-y-1 glass-card h-full border-white/5 hover:border-primary/30 group card-hover-lift gradient-border-hover\"><div class=\"p-8\"><div class=\"w-14 h-14 rounded-2xl flex items-center justify-center mb-6 group-hover:scale-110 transition-transform duration-500 bg-rose-500/10 text-rose-400 border border-rose-500/20 shadow-lg shadow-rose-500/20\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-command w-8 h-8\" aria-hidden=\"true\"><path d=\"M15 6v12a3 3 0 1 0 3-3H6a3 3 0 1 0 3 3V6a3 3 0 1 0-3 3h12a3 3 0 1 0-3-3\"></path></svg></div><h3 class=\"text-xl font-bold mb-4\">CLI Power</h3><p class=\"text-white/40 leading-relaxed\">Deploy and manage your environment from any terminal with our CLI tool.</p></div></div></div></div></div></section><section id=\"pricing\" class=\"py-32 px-6 relative\"><div class=\"max-w-7xl mx-auto\"><div class=\"text-center mb-20\"><h2 class=\"text-4xl md:text-5xl font-bold mb-6 italic italic-accent\">Simple, Transparent Pricing</h2><p class=\"text-white/40 text-lg max-w-2xl mx-auto\">Start for free, upgrade when you need more power.</p></div><div class=\"grid grid-cols-1 md:grid-cols-3 gap-8\"><div class=\"rounded-xl border bg-card/40 text-card-foreground shadow-sm backdrop-blur-md hover:bg-card/60 hover:shadow-md hover:-translate-y-1 glass-card border-white/5 relative overflow-hidden group hover:border-primar